<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1>Регистрация на сайте</h1>

    <form>
      <label>Введите Имя</label>
      <input type="text" placeholder="Имя" />
      <br />
      <label>Введите Фамилию</label>
      <input type="text" placeholder="Фамилию" />
      <br />
      <label>Введите Почту</label>
      <input type="email" placeholder="Почту" />
      <h2>Пароль</h2>
      <label>Введите Пароль</label>
      <input type="password" placeholder="пароль" />

      <label>Введите Возраст</label>
      <input type="number" min="0" max="120" placeholder="возраст" />
      <br />

      <label>Согласен с правилами?</label>
      <input type="radio" />да <input type="radio" />нет
      <br />
      <h2>Зарегистрироваться</h2>
      <button type="submit">Зарегистрироваться</button>
    </form>
  </body>
</html>
